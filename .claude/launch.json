{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "JLYCC App",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "app"],
      "port": 3000
    },
    {
      "name": "jlycc-dev-localdb",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-NoProfile",
        "-Command",
        "$env:DATABASE_URL='postgresql://jly_admin:localdevpassword@localhost:5432/jly'; $env:DATABASE_URL_READER=$env:DATABASE_URL; npm run dev --prefix app"
      ],
      "port": 3000
    },
    {
      "name": "jlycc-worktree-redesign-localdb",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-NoProfile",
        "-Command",
        "$env:DATABASE_URL='postgresql://jly_admin:localdevpassword@localhost:5432/jly'; $env:DATABASE_URL_READER=$env:DATABASE_URL; $env:PORT='3001'; npm run dev --prefix '.worktrees/member-dashboard-redesign/app' -- -p 3001"
      ],
      "port": 3001
    }
  ]
}
